---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/index/Hero.astro';
import Schedules from '@/components/index/Schedules.astro';

const preloadImages = [
	{
		href: "/images/home/hero-buenos-aires-mobile.webp",
		as: "image",
		type: "image/webp",
	},
	{
		href: "/images/home/hero-buenos-aires.webp",
		as: "image",
		type: "image/webp",
	},
];
---

<Layout
	title="LA UNION S.R.L. | Transporte de Pasajeros"
	canonical="https://launionsrl.com.ar"
	metaDescription="LA UNION S.R.L. conecta destinos y acerca historias. Comprá pasajes de colectivo de media y larga distancia de forma rápida, segura y confiable."
	metaImg="/images/home/hero-buenos-aires-mobile.webp"
	preLoad={preloadImages}
	hideFooter={false}
>
	<Hero />
	<Schedules />
</Layout>
