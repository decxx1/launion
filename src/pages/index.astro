---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/index/Hero.astro';
import Schedules from '@/components/index/Schedules.astro';
import TourPackages from '@/components/index/TourPackages.astro';
import AboutUs from '@/components/index/AboutUs.astro';
import Units from '@/components/index/Units.astro';

const preloadImages = [
	{
		href: "/images/home/hero-mobile.webp",
		as: "image",
		type: "image/webp",
	},
	{
		href: "/images/home/hero.webp",
		as: "image",
		type: "image/webp",
	},
];
---

<Layout
	title="LA UNION S.R.L. | Transporte de Pasajeros"
	canonical="https://launionsrl.com.ar"
	metaDescription="LA UNION S.R.L. conecta destinos y acerca historias. Comprá tus pasajes de colectivo de larga distancia de forma rápida y segura."
	metaImg="/images/home/hero.webp"
	preLoad={preloadImages}
	hideFooter={true}
>
	<Hero />
	<Schedules />
	<TourPackages />
	<AboutUs />
	<Units />
</Layout>
