---
import ArrowImageBanner from "@/components/ArrowImageBanner.astro";
import ContactoForm from "@/components/contacto/ContactoForm.tsx";

const mapSrc =
	"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3268.392970718099!2d-67.5133268533738!3d-34.99686684531412!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x967805a357d5ddc3%3A0x71376de8a5b320e5!2sLa%20Union%20S.R.L.!5e0!3m2!1ses!2sar!4v1783709387463!5m2!1ses!2sar";
---

<section class="relative overflow-hidden bg-[#dce8f0] pt-28 pb-12 sm:pt-32 sm:pb-16 lg:pt-36 lg:pb-20">
	<!-- Rombo de fondo -->
	<div
		class="pointer-events-none absolute inset-0 overflow-hidden"
		aria-hidden="true"
	>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			loading="lazy"
			alt="rombo de fondo azul para el contacto"
			class="absolute top-[72%] left-0 h-[110vh] w-auto max-w-none translate-x-[-70%] -translate-y-1/2 select-none sm:top-[66%] sm:left-10 sm:h-[115vh] lg:hidden"
		/>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			loading="lazy"
			alt="rombo de fondo azul para el contacto"
			class="absolute top-1/2 left-0 hidden h-[200vh] w-auto max-w-none translate-x-[-56%] -translate-y-1/2 select-none lg:block xl:h-[300vh] 2xl:translate-x-[-40%]"
		/>
	</div>

	<ArrowImageBanner
		id="contacto-banner"
		image="/images/contacto/atencion-cliente.webp"
		imageAlt="Atención al cliente de LA UNION S.R.L."
		align="end"
	>
		<h1 class="text-left text-lg sm:text-2xl md:text-3xl xl:text-4xl">
			Contactanos y <br class="hidden sm:block" />
			hacé tu consulta.
		</h1>
	</ArrowImageBanner>

	<!-- Formulario + mapa centrados; azul desde el margen izquierdo hasta el mapa -->
	<div class="relative z-10 mt-10 sm:mt-12 lg:mt-16">
		<div class="relative mx-auto max-w-7xl">
			<div
				class="pointer-events-none absolute inset-y-0 right-0 left-[calc(50%-50vw)] rounded-r-3xl bg-launion xl:rounded-r-[2.5rem]"
				aria-hidden="true"
			></div>

			<div
				class="relative z-10 grid grid-cols-1 gap-8 px-5 py-8 sm:px-8 sm:py-10 lg:grid-cols-2 lg:gap-10 lg:px-10 lg:py-12 xl:gap-14"
			>
				<ContactoForm client:load />

				<!-- Mapa + datos -->
				<div class="flex flex-col gap-5">
					<div
						class="aspect-square w-full overflow-hidden rounded-2xl bg-white/10 sm:aspect-4/3 lg:aspect-square"
					>
						<iframe
							src={mapSrc}
							title="Ubicación de LA UNION S.R.L. en Google Maps"
							class="h-full w-full border-0"
							allowfullscreen
							loading="lazy"
							referrerpolicy="strict-origin-when-cross-origin"
						></iframe>
					</div>
					<div class="space-y-1 text-sm font-medium text-white sm:text-base">
						<p>Calle Centenario 150, Bowen, Gral. Alvear, Mendoza.</p>
						<a
							href="tel:+542625480041"
							class="block transition-opacity hover:opacity-80"
						>
							(2625) 480041
						</a>
						<a
							href="mailto:info@launionsrl.com.ar"
							class="block transition-opacity hover:opacity-80"
						>
							info@launionsrl.com.ar
						</a>
						<p>Horarios de atención: lunes a sábado 8 a 12 h y 16.30 a 20 h.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
