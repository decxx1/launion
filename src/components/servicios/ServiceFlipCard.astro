---
import type { ServicioGalleryImage } from "@/data/serviciosGallery";

interface Props {
	id: string;
	images: ServicioGalleryImage[];
	compact?: boolean;
	perPage?: number;
	class?: string;
}

const { id, images, compact = false, perPage = 2, class: className } = Astro.props;
const galleryId = `${id}-gallery`;
const lightboxData = JSON.stringify(images.map(({ src, alt }) => ({ src, alt })));

const pages: ServicioGalleryImage[][] = [];
for (let i = 0; i < images.length; i += perPage) {
	pages.push(images.slice(i, i + perPage));
}

const galleryHeightClass = compact ? "h-36 sm:h-40" : "h-40 sm:h-44 lg:h-48";
const pageGridClass = perPage >= 4 ? "grid-cols-2 sm:grid-cols-4" : "grid-cols-2";
---

<div
	class:list={[
		"service-flip-card perspective-[1200px]",
		compact && "transition-[min-height] duration-500 ease-in-out motion-reduce:transition-none",
		className,
	]}
	data-service-flip
	data-compact={compact ? "true" : undefined}
	data-per-page={perPage}
>
	<div
		class="service-flip-inner relative h-full transition-transform duration-500 ease-in-out [transform-style:preserve-3d] motion-reduce:transition-none"
	>
		<div
			class:list={[
				"service-flip-front relative [backface-visibility:hidden]",
				compact ? "pb-10 sm:pb-11" : "pb-12 sm:pb-14",
			]}
		>
			<slot />

			<button
				type="button"
				class:list={[
					"service-flip-open absolute z-10 inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-white transition hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:text-sm",
					compact ? "bottom-3 right-4 sm:bottom-4 sm:right-5" : "bottom-4 right-5 sm:bottom-5 sm:right-6",
				]}
				aria-expanded="false"
				aria-controls={galleryId}
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					class="size-4 shrink-0"
					aria-hidden="true"
				>
					<rect x="3" y="3" width="18" height="18" rx="2" />
					<circle cx="8.5" cy="8.5" r="1.5" />
					<path d="m21 15-5-5L5 21" />
				</svg>
				Ver fotos
			</button>
		</div>

		<div
			id={galleryId}
			class="service-flip-back absolute inset-0 flex flex-col overflow-hidden rounded-2xl bg-launion [backface-visibility:hidden] [transform:rotateY(180deg)]"
			aria-hidden="true"
			inert
		>
			<div class="flex shrink-0 items-center justify-between gap-3 px-4 pt-4 sm:px-5">
				<button
					type="button"
					class="service-flip-close inline-flex items-center gap-1.5 rounded-full border border-white/30 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-white transition hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:text-sm"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						class="size-4"
						aria-hidden="true"
					>
						<path d="m15 18-6-6 6-6" />
					</svg>
					Volver
				</button>
				<p
					class="service-flip-counter text-xs font-semibold tabular-nums text-white/80 sm:text-sm"
					aria-live="polite"
				>
					1 / {pages.length}
				</p>
			</div>

			<div
				class="service-flip-track relative mt-3 flex min-h-0 flex-1 flex-col px-4 pb-4 sm:px-5 sm:pb-5"
				data-lightbox-gallery={lightboxData}
				data-page-count={pages.length}
			>
				<div
					class:list={[
						"relative min-h-0 flex-1 overflow-hidden rounded-xl",
						compact ? "min-h-[9rem] sm:min-h-[10rem]" : galleryHeightClass,
					]}
				>
					{
						pages.map((page, pageIndex) => (
							<div
								class:list={[
									"service-flip-page absolute inset-0 grid gap-2 transition-opacity duration-300 sm:gap-3",
									pageGridClass,
								]}
								data-page={pageIndex}
								data-active={pageIndex === 0 ? "true" : "false"}
								hidden={pageIndex !== 0}
							>
								{page.map((image, imageIndex) => {
									const globalIndex = pageIndex * perPage + imageIndex;
									return (
										<button
											type="button"
											class="group/photo relative h-full min-h-0 overflow-hidden rounded-lg ring-1 ring-white/15 transition hover:ring-white/40 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
											data-lightbox-open
											data-lightbox-index={globalIndex}
											aria-label={`Ver en alta calidad: ${image.alt}`}
										>
											<img
												src={image.thumb}
												alt={image.alt}
												class="h-full w-full object-cover transition duration-300 group-hover/photo:scale-[1.03]"
												loading="lazy"
												decoding="async"
												draggable="false"
											/>
											<span class="pointer-events-none absolute inset-x-0 bottom-0 bg-linear-to-t from-black/50 to-transparent px-2 py-1.5 text-left text-[10px] font-semibold uppercase tracking-wide text-white opacity-0 transition group-hover/photo:opacity-100 sm:text-[11px]">
												Ampliar
											</span>
										</button>
									);
								})}
							</div>
						))
					}

					{
						pages.length > 1 && (
							<>
								<button
									type="button"
									class="service-flip-prev absolute top-1/2 left-1.5 z-10 flex size-8 -translate-y-1/2 items-center justify-center rounded-full bg-black/45 text-white transition hover:bg-black/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:left-2 sm:size-9"
									aria-label="Fotos anteriores"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										class="size-5"
										aria-hidden="true"
									>
										<path d="m15 18-6-6 6-6" />
									</svg>
								</button>
								<button
									type="button"
									class="service-flip-next absolute top-1/2 right-1.5 z-10 flex size-8 -translate-y-1/2 items-center justify-center rounded-full bg-black/45 text-white transition hover:bg-black/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:right-2 sm:size-9"
									aria-label="Fotos siguientes"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										class="size-5"
										aria-hidden="true"
									>
										<path d="m9 18 6-6-6-6" />
									</svg>
								</button>
							</>
						)
					}
				</div>

				{
					pages.length > 1 && (
						<div
							class="mt-3 flex justify-center gap-2"
							role="tablist"
							aria-label="Seleccionar grupo de fotos"
						>
							{pages.map((_, pageIndex) => (
								<button
									type="button"
									class="service-flip-dot size-2.5 rounded-full bg-white/35 transition hover:bg-white/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white data-[active=true]:scale-110 data-[active=true]:bg-white"
									data-dot={pageIndex}
									data-active={pageIndex === 0 ? "true" : "false"}
									role="tab"
									aria-label={`Grupo ${pageIndex + 1}`}
									aria-selected={pageIndex === 0 ? "true" : "false"}
								/>
							))}
						</div>
					)
				}
			</div>
		</div>
	</div>
</div>

<style>
	.service-flip-card.is-flipped .service-flip-inner {
		transform: rotateY(180deg);
	}

	.service-flip-card.is-flipped[data-compact] .service-flip-inner {
		height: 100%;
	}

	.service-flip-card.is-flipped .service-flip-front {
		visibility: hidden;
	}

	.service-flip-card.is-flipped[data-compact] .service-flip-front {
		position: absolute;
		inset: 0;
		width: 100%;
	}

	.service-flip-card.is-flipped .service-flip-open {
		visibility: hidden;
		opacity: 0;
		pointer-events: none;
	}

	.service-flip-page[data-active="true"] {
		opacity: 1;
		pointer-events: auto;
	}

	.service-flip-page[data-active="false"] {
		opacity: 0;
		pointer-events: none;
	}

	.service-flip-back.is-measuring {
		position: relative !important;
		inset: auto !important;
		transform: none !important;
		visibility: hidden;
		pointer-events: none;
	}
</style>

<script>
	const FLIP_TRANSITION_MS = 500;

	function measureBackHeight(back: HTMLElement, card: HTMLElement) {
		back.classList.add("is-measuring");
		back.style.width = `${card.offsetWidth}px`;
		const height = back.offsetHeight;
		back.style.width = "";
		back.classList.remove("is-measuring");
		return height;
	}

	function initServiceFlipCards() {
		document.querySelectorAll<HTMLElement>("[data-service-flip]").forEach((card) => {
			if (card.dataset.initialized === "true") return;
			card.dataset.initialized = "true";

			const isCompact = card.dataset.compact === "true";
			const inner = card.querySelector<HTMLElement>(".service-flip-inner");
			const front = card.querySelector<HTMLElement>(".service-flip-front");
			const openBtn = card.querySelector<HTMLButtonElement>(".service-flip-open");
			const closeBtn = card.querySelector<HTMLButtonElement>(".service-flip-close");
			const back = card.querySelector<HTMLElement>(".service-flip-back");
			const track = card.querySelector<HTMLElement>(".service-flip-track");
			const counter = card.querySelector<HTMLElement>(".service-flip-counter");
			const pageEls = Array.from(card.querySelectorAll<HTMLElement>(".service-flip-page"));
			const dots = Array.from(card.querySelectorAll<HTMLButtonElement>(".service-flip-dot"));
			const prevBtn = card.querySelector<HTMLButtonElement>(".service-flip-prev");
			const nextBtn = card.querySelector<HTMLButtonElement>(".service-flip-next");

			if (!inner || !front || !openBtn || !closeBtn || !back || pageEls.length === 0) return;

			let currentPage = 0;
			let touchStartX = 0;

			const updatePage = (index: number) => {
				currentPage = (index + pageEls.length) % pageEls.length;

				pageEls.forEach((page, pageIndex) => {
					const isActive = pageIndex === currentPage;
					page.dataset.active = isActive ? "true" : "false";
					page.hidden = !isActive;
				});

				dots.forEach((dot, dotIndex) => {
					const isActive = dotIndex === currentPage;
					dot.dataset.active = isActive ? "true" : "false";
					dot.setAttribute("aria-selected", isActive ? "true" : "false");
				});

				if (counter) {
					counter.textContent = `${currentPage + 1} / ${pageEls.length}`;
				}
			};

			const setCompactHeight = (height: number | null) => {
				if (!isCompact) return;
				const value = height === null ? "" : `${height}px`;
				card.style.minHeight = value;
				inner.style.minHeight = value;
			};

			const setFlipped = (flipped: boolean) => {
				if (flipped) {
					if (isCompact) {
						back.removeAttribute("inert");
						const expandedHeight = Math.max(
							front.offsetHeight,
							measureBackHeight(back, card),
						);
						setCompactHeight(front.offsetHeight);
						requestAnimationFrame(() => {
							setCompactHeight(expandedHeight);
							card.classList.add("is-flipped");
						});
					} else {
						card.classList.add("is-flipped");
						back.removeAttribute("inert");
					}

					openBtn.setAttribute("aria-expanded", "true");
					back.setAttribute("aria-hidden", "false");
					updatePage(currentPage);
					return;
				}

				card.classList.remove("is-flipped");
				openBtn.setAttribute("aria-expanded", "false");
				back.setAttribute("aria-hidden", "true");
				back.setAttribute("inert", "");

				if (isCompact) {
					setCompactHeight(front.offsetHeight);
					window.setTimeout(() => setCompactHeight(null), FLIP_TRANSITION_MS);
				}
			};

			openBtn.addEventListener("click", () => setFlipped(true));
			closeBtn.addEventListener("click", () => setFlipped(false));

			prevBtn?.addEventListener("click", (event) => {
				event.stopPropagation();
				updatePage(currentPage - 1);
			});

			nextBtn?.addEventListener("click", (event) => {
				event.stopPropagation();
				updatePage(currentPage + 1);
			});

			dots.forEach((dot) => {
				dot.addEventListener("click", (event) => {
					event.stopPropagation();
					const index = Number(dot.dataset.dot);
					if (!Number.isNaN(index)) updatePage(index);
				});
			});

			track?.addEventListener(
				"touchstart",
				(event) => {
					touchStartX = event.changedTouches[0]?.clientX ?? 0;
				},
				{ passive: true },
			);

			track?.addEventListener(
				"touchend",
				(event) => {
					const touchEndX = event.changedTouches[0]?.clientX ?? 0;
					const delta = touchStartX - touchEndX;

					if (Math.abs(delta) < 40) return;
					updatePage(delta > 0 ? currentPage + 1 : currentPage - 1);
				},
				{ passive: true },
			);

			card.addEventListener("keydown", (event) => {
				if (!card.classList.contains("is-flipped")) return;

				if (event.key === "Escape") {
					const lightbox = document.getElementById("servicios-lightbox");
					if (lightbox && !lightbox.hidden) return;

					setFlipped(false);
					openBtn.focus();
				}

				if (event.key === "ArrowLeft") updatePage(currentPage - 1);
				if (event.key === "ArrowRight") updatePage(currentPage + 1);
			});
		});
	}

	initServiceFlipCards();
</script>
