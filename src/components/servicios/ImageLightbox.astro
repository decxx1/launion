---
---

<div
	id="servicios-lightbox"
	class="fixed inset-0 z-50 hidden items-center justify-center bg-black/85 p-4 sm:p-8"
	role="dialog"
	aria-modal="true"
	aria-label="Vista ampliada de imagen"
	hidden
>
	<button
		type="button"
		class="absolute top-4 right-4 z-10 flex size-10 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
		data-lightbox-close
		aria-label="Cerrar"
	>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-6" aria-hidden="true">
			<path d="M18 6 6 18M6 6l12 12" />
		</svg>
	</button>

	<button
		type="button"
		class="absolute top-1/2 left-3 z-10 flex size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:left-6"
		data-lightbox-prev
		aria-label="Imagen anterior"
		hidden
	>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-6" aria-hidden="true">
			<path d="m15 18-6-6 6-6" />
		</svg>
	</button>

	<button
		type="button"
		class="absolute top-1/2 right-3 z-10 flex size-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:right-6"
		data-lightbox-next
		aria-label="Imagen siguiente"
		hidden
	>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-6" aria-hidden="true">
			<path d="m9 18 6-6-6-6" />
		</svg>
	</button>

	<figure class="flex max-h-[85vh] max-w-6xl flex-col items-center gap-3">
		<img
			class="max-h-[78vh] w-auto max-w-full rounded-lg object-contain shadow-2xl"
			data-lightbox-image
			alt=""
		/>
		<figcaption class="text-sm font-medium text-white/85" data-lightbox-caption aria-live="polite"></figcaption>
		<p class="text-xs font-semibold tabular-nums text-white/60" data-lightbox-counter></p>
	</figure>
</div>

<script>
	interface LightboxImage {
		src: string;
		alt: string;
	}

	let lightboxImages: LightboxImage[] = [];
	let lightboxIndex = 0;
	let lastFocusedElement: HTMLElement | null = null;

	const lightbox = document.getElementById("servicios-lightbox");
	const lightboxImage = lightbox?.querySelector<HTMLImageElement>("[data-lightbox-image]");
	const lightboxCaption = lightbox?.querySelector<HTMLElement>("[data-lightbox-caption]");
	const lightboxCounter = lightbox?.querySelector<HTMLElement>("[data-lightbox-counter]");
	const closeBtn = lightbox?.querySelector<HTMLButtonElement>("[data-lightbox-close]");
	const prevBtn = lightbox?.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
	const nextBtn = lightbox?.querySelector<HTMLButtonElement>("[data-lightbox-next]");

	const parseGallery = (element: Element | null): LightboxImage[] => {
		if (!element) return [];

		try {
			return JSON.parse(element.getAttribute("data-lightbox-gallery") ?? "[]") as LightboxImage[];
		} catch {
			return [];
		}
	};

	const updateLightbox = () => {
		if (!lightboxImage || !lightboxCaption || !lightboxCounter || lightboxImages.length === 0) return;

		const image = lightboxImages[lightboxIndex];
		lightboxImage.src = image.src;
		lightboxImage.alt = image.alt;
		lightboxCaption.textContent = image.alt;
		lightboxCounter.textContent = `${lightboxIndex + 1} / ${lightboxImages.length}`;

		const showNav = lightboxImages.length > 1;
		prevBtn?.toggleAttribute("hidden", !showNav);
		nextBtn?.toggleAttribute("hidden", !showNav);
	};

	const openLightbox = (images: LightboxImage[], index: number) => {
		if (!lightbox || images.length === 0) return;

		lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
		lightboxImages = images;
		lightboxIndex = (index + images.length) % images.length;
		updateLightbox();

		lightbox.hidden = false;
		lightbox.classList.remove("hidden");
		lightbox.classList.add("flex");
		document.body.style.overflow = "hidden";
		closeBtn?.focus();
	};

	const closeLightbox = () => {
		if (!lightbox || !lightboxImage) return;

		lightbox.hidden = true;
		lightbox.classList.add("hidden");
		lightbox.classList.remove("flex");
		document.body.style.overflow = "";
		lightboxImage.removeAttribute("src");
		lastFocusedElement?.focus();
	};

	const stepLightbox = (direction: number) => {
		if (lightboxImages.length === 0) return;
		lightboxIndex = (lightboxIndex + direction + lightboxImages.length) % lightboxImages.length;
		updateLightbox();
	};

	if (!lightbox?.dataset.initialized) {
		lightbox.dataset.initialized = "true";

		document.addEventListener("click", (event) => {
			const target = event.target as Element;
			const openTrigger = target.closest<HTMLElement>("[data-lightbox-open]");

			if (openTrigger) {
				event.preventDefault();
				event.stopPropagation();

				const gallery = openTrigger.closest("[data-lightbox-gallery]");
				const images = parseGallery(gallery);
				const index = Number(openTrigger.dataset.lightboxIndex ?? "0");

				if (images.length > 0) openLightbox(images, index);
				return;
			}

			if (target === lightbox) closeLightbox();
		});

		closeBtn?.addEventListener("click", closeLightbox);
		prevBtn?.addEventListener("click", () => stepLightbox(-1));
		nextBtn?.addEventListener("click", () => stepLightbox(1));

		document.addEventListener("keydown", (event) => {
			if (lightbox.hidden) return;

			if (event.key === "Escape") closeLightbox();
			if (event.key === "ArrowLeft") stepLightbox(-1);
			if (event.key === "ArrowRight") stepLightbox(1);
		});
	}
</script>
