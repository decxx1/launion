---
import ArrowImageBanner from "@/components/ArrowImageBanner.astro";

const mediaDistanciaFeatures = [
	"Semicama para recorridos provinciales.",
	"Servicio a bordo: bebida y snack.",
	"Pantallas de 23''.",
	"Wifi.",
];

const camaEjecutivoFeatures = [
	"Servicio a bordo: comida fría o caliente a elección, postre y bebida, merienda y desayuno.",
	"Pantallas de 23 pulgadas",
	"Wifi y puertos USB",
	"Reclinación 160°, reposacabezas ergonómico y climatización integral.",
	"Mantas y almohadas individuales.",
	"Atención personalizada.",
];

const camaSuiteFeatures = [
	"Servicio a bordo: comida fría o caliente a elección, postre y bebida, merienda y desayuno.",
	"Pantallas individuales.",
	"Wifi y puertos USB",
	"Reclinación total, reposacabezas ergonómico y climatización integral.",
	"Mantas y almohadas individuales.",
	"Atención personalizada.",
];
---

<section class="relative overflow-hidden bg-white pt-28 pb-10 sm:pt-32 sm:pb-12 lg:pt-36 lg:pb-16">
	<!-- Rombo de fondo -->
	<div
		class="pointer-events-none absolute inset-0 overflow-hidden"
		aria-hidden="true"
	>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt=""
			class="absolute top-[72%] left-0 h-[110vh] w-auto max-w-none translate-x-[-70%] -translate-y-1/2 select-none sm:top-[66%] sm:left-10 sm:h-[115vh] lg:hidden"
		/>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt=""
			class="absolute top-1/2 left-0 hidden h-[165vh] w-auto max-w-none translate-x-[-56%] -translate-y-1/2 select-none lg:block xl:h-[175vh] xl:translate-x-[-58%] 2xl:translate-x-[-46%]"
		/>
	</div>

	<ArrowImageBanner
		id="servicios-top"
		image="/images/servicios/unidades.webp"
		imageAlt="Interiores de colectivos de LA UNION S.R.L."
		align="end"
	>
		<h2 class="text-left ml-8 text-lg sm:text-2xl md:text-3xl xl:text-4xl">
			Servicio <br class="hidden sm:block" />
			en nuestras unidades
		</h2>
	</ArrowImageBanner>

	<div class="relative z-10 container mx-auto max-w-7xl px-4">
		<!-- Intro -->
		<div class="mx-auto mt-8 max-w-7xl space-y-2 sm:mt-10 text-left font-semibold text-sm sm:text-base lg:text-lg">
			<p>
				Viajar con Unión es hacerlo con confort, seguridad y tecnología al
				servicio de cada pasajero.
			</p>
			<p>
				Contamos con unidades preparadas para distintos tipos de recorrido,
				desde traslados urbanos hasta viajes de media y larga distancia.
			</p>
		</div>

		<!-- Cards -->
		<div class="mt-8 space-y-4 sm:mt-10 sm:space-y-5">
			<div class="grid grid-cols-1 gap-4 lg:grid-cols-2 sm:gap-5">
				<!-- Urbano -->
				<div
					class="grid grid-cols-12 gap-2 sm:gap-4 rounded-2xl bg-launion px-5 py-5 text-white sm:px-6 sm:py-6"
				>
					<div class="col-span-12 xs:col-span-3 flex items-center justify-center">
						<img
							src="/images/icons/icon-bus.svg"
							alt="ícono de un micro"
							class="size-12 sm:size-14 md:size-24"
							aria-hidden="true"
						/>
					</div>
					<div class="col-span-12 xs:col-span-9 self-start">
						<h3 class="text-2xl md:text-3xl lg:text-4xl font-bold uppercase">Urbano</h3>
						<p class="mt-1 text-sm sm:text-base font-medium list-disc">
							<li>Micros destinados a recorridos cortos o urbanos.</li>
						</p>
					</div>
				</div>

				<!-- Media distancia -->
				<div
					class="grid grid-cols-12 gap-2 sm:gap-4 rounded-2xl bg-launion px-5 py-5 text-white sm:px-6 sm:py-6"
				>
					<div class="col-span-12 xs:col-span-3 flex items-center justify-center">
						<img
							src="/images/icons/icon-bus.svg"
							alt="ícono de un micro"
							class="size-12 sm:size-14 md:size-24"
							aria-hidden="true"
						/>
					</div>
					<div class="col-span-12 xs:col-span-9 self-start">
						<h3 class="text-2xl md:text-3xl lg:text-4xl font-bold uppercase">
							Media distancia
						</h3>
						<ul class="mt-2 space-y-0.5 text-sm sm:text-base font-medium list-disc">
							{
								mediaDistanciaFeatures.map((feature) => (
									<li>{feature}</li>
								))
							}
						</ul>
					</div>
				</div>
			</div>

			<!-- Larga distancia -->
			<div class="rounded-2xl bg-launion px-5 py-6 text-white sm:px-8 sm:py-8">
				<h3
					class="mb-16 lg:mb-10 text-center text-2xl md:text-3xl lg:text-4xl font-bold uppercase"
				>
					Larga distancia
				</h3>
				<div
					class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-0 lg:divide-x-2 lg:divide-white"
				>
					<!-- Cama ejecutivo -->
					<div
						class="flex flex-col gap-4 lg:pr-8"
					>
						<h4 class="text-lg sm:text-xl md:text-2xl font-bold uppercase">
							Cama ejecutivo
						</h4>
						<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-6">
							<img
								src="/images/icons/ejecutive.svg"
								alt="iconos de cama ejecutivo"
								class="mr-auto w-36 shrink-0 sm:mx-0 sm:w-40 lg:w-44"
								aria-hidden="true"
							/>
							<div>
								
								<ul class="mt-2 md:mt-0 space-y-1 text-sm sm:text-base font-medium list-disc">
									{
										camaEjecutivoFeatures.map((feature) => (
											<li>{feature}</li>
										))
									}
								</ul>
							</div>
						</div>
					</div>

					<!-- Cama suite -->
					<div
						class="flex flex-col gap-4 lg:pl-8"
					>
						<h4 class="text-lg sm:text-xl md:text-2xl font-bold uppercase">
							Cama suite
						</h4>
						<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-6">
							<img
								src="/images/icons/suite.svg"
								alt="iconos de cama suite"
								class="mr-auto w-36 shrink-0 sm:mx-0 sm:w-40 lg:w-44"
								aria-hidden="true"
							/>
							<div>
								
								<ul class="mt-2 md:mt-0 space-y-1 text-sm sm:text-base font-medium list-disc">
									{
										camaSuiteFeatures.map((feature) => (
											<li>{feature}</li>
										))
									}
								</ul>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Outro -->
		<p class="mx-auto mt-8 max-w-7xl text-left font-semibold text-sm sm:mt-10 sm:text-base lg:text-lg">
			Nuestras unidades están equipadas con sistemas avanzados como frenos ABS,
			control de estabilidad y señalización inteligente, junto a un
			mantenimiento constante que garantiza viajes confiables.
		</p>
	</div>

	<ArrowImageBanner
		id="servicios-bottom"
		image="/images/servicios/suite-ejecutivo.webp"
		imageAlt="Cama ejecutivo y suite de LA UNION S.R.L."
		align="start"
	>
		<p class="text-base xs:text-lg sm:text-xl md:text-2xl xl:text-4xl">Con Unión disfrutás cada kilómetro del camino.</p>
	</ArrowImageBanner>
</section>
