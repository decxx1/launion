---
interface Props {
	title: string;
	id?: string;
}

const { title, id = "page-title-header" } = Astro.props;
const clipId = `${id}-clip`;
---

<div class="relative z-10 mb-10 sm:mb-12 lg:mb-16">
	<div class="relative lg:mx-auto max-w-96 sm:max-w-xl md:max-w-3xl lg:max-w-5xl xl:max-w-7xl">
		<div class="relative h-16 overflow-visible sm:h-20 lg:h-24">
			<div
				class="pointer-events-none absolute inset-y-0 right-0 left-[calc(50%-50vw)] bg-launion"
				style={`clip-path: url(#${clipId});`}
				aria-hidden="true"
			></div>

			<div class="relative z-10 flex h-full w-full items-center">
				<h1
					class="pl-8 sm:pl-12 md:pl-16 lg:pl-20 pr-36 sm:pr-44 lg:pr-56 text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold text-white"
				>
					{title}
				</h1>
				<img
					src="/images/paquetes/colectivo-la-union.webp"
					alt="Colectivo de LA UNION S.R.L."
					class="absolute top-[58%] sm:top-[60%] right-6 sm:right-8 md:right-10 lg:right-16 z-20 h-auto w-40 sm:w-52 md:w-60 lg:w-72 xl:w-80 -translate-y-1/2 drop-shadow-lg"
					loading="lazy"
				/>
			</div>
		</div>
	</div>
</div>

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
	<defs>
		<clipPath id={clipId} clipPathUnits="objectBoundingBox">
			<path
				d="M 0 1 L 0 0 L 0.945 0 Q 0.965 0 0.966 0.020 L 0.9983 0.4751 Q 1 0.5 0.9983 0.5249 L 0.966 0.980 Q 0.965 1 0.945 1 L 0 1 Z"
			></path>
		</clipPath>
	</defs>
</svg>
