---
import {
	SCHEDULES,
	PHONE,
	PHONE_FORMAT,
	ADDRESS,
	MAP_URL,
} from "astro:env/server";
import { WHATSAPP_PHONE, EMAIL } from "astro:env/client";

const currentPath =
	Astro.url.pathname.replace(/\/$/, "") || "/";

const infoLinks = [
	{ label: "Preguntas frecuentes", href: "/preguntas-frecuentes" },
	{ label: "Política de seguridad", href: "/politica-de-seguridad" },
];

const externalLinks = [
	{
		label: "Pasajes",
		href: "https://abmws.com.ar/luweb-nuebus/sale/paso1.php",
	},
	{
		label: "Encomiendas",
		href: "https://launionsrl.com:8443/",
	},
];

const phoneHref = PHONE ? `tel:+54${PHONE}` : undefined;
const whatsappHref = WHATSAPP_PHONE
	? `https://wa.me/${WHATSAPP_PHONE}`
	: undefined;
const whatsappFormat = WHATSAPP_PHONE
	? `(${WHATSAPP_PHONE.slice(0, 4)}) – ${WHATSAPP_PHONE.slice(4)}`
	: undefined;
const emailHref = EMAIL ? `mailto:${EMAIL}` : undefined;

function isActiveLink(href: string): boolean {
	if (href === "/") return currentPath === "/";
	return currentPath === href;
}
---

<footer
	class="px-4 pb-6 sm:px-6 sm:pb-8 lg:px-8 overflow-hidden relative"
>
	<!-- Rombo de fondo (lado izquierdo) -->
	<div
		class="pointer-events-none absolute inset-0 overflow-hidden"
		aria-hidden="true"
	>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt="figura de rombo para el fondo"
			loading="lazy"
			class="absolute top-1/2 left-0 h-[165vh] w-auto max-w-none translate-x-[-56%] -translate-y-1/2 select-none xl:h-[175vh] xl:translate-x-[-58%] 2xl:translate-x-[-46%]"
		/>
	</div>
	<div
		class="footer-card relative z-10 mx-auto max-w-7xl overflow-hidden rounded-tl-[3.5rem] rounded-br-[3.5rem] bg-launion text-white"
	>
		<div
			class="pointer-events-none absolute inset-0 overflow-hidden"
			aria-hidden="true"
		>
			<img
				src="/images/shapes/shape-diamond-bg.svg"
				alt="fondo de rombo"
				loading="lazy"
				class="absolute -right-24 -bottom-32 h-[70vh] w-auto max-w-none opacity-[0.08] select-none sm:-right-16 sm:h-[80vh] lg:-right-8"
			/>
		</div>

		<div class="relative z-10 px-5 py-4 sm:px-8 sm:py-6 lg:px-10 lg:py-8">
			<div
				class="grid grid-cols-1 gap-10 sm:gap-12 md:grid-cols-2 lg:grid-cols-12 lg:gap-x-10 xl:gap-x-14"
			>
				<!-- Logo y resumen -->
				<div class="flex flex-col items-center text-center lg:col-span-3">
					<a href="/" aria-label="LA UNION S.R.L. - Inicio">
						<img
							src="/images/logos/logo.svg"
							alt="Logo LA UNION S.R.L."
							class="mx-auto h-auto w-40 sm:w-48"
							width="279"
							height="119"
							loading="lazy"
							data-aos="flip-left"
						/>
					</a>
					<div
						class="mt-5 max-w-md space-y-3 text-sm leading-relaxed font-medium text-white/85 sm:mt-6 sm:text-base"
						data-aos="fade"
					>
						<p>
							Ofrecemos una experiencia integral que comienza en el viaje y
							continúa en cada destino.
						</p>
					</div>
				</div>

				<!-- Información -->
				<div class="lg:col-span-3">
					<h3
						class="mb-4 text-[0.8125rem] font-bold tracking-[0.08em] uppercase text-white sm:mb-5 sm:text-sm"
						data-aos="flip-up"
					>
						Información
					</h3>
					<ul class="flex flex-col gap-2.5 sm:gap-3">
						{
							infoLinks.map((link, index) => (
								<li>
									<a
										href={link.href}
										class:list={[
											"group inline-flex items-center gap-1 text-sm font-semibold text-white/80 transition-colors duration-200 hover:text-white sm:text-[0.9375rem]",
											isActiveLink(link.href) &&
												"text-white underline underline-offset-4",
										]}
										aria-current={isActiveLink(link.href) ? "page" : undefined}
										data-aos="fade"
										data-aos-duration="500"
										data-aos-delay={index * 300}
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											class="size-3.5 shrink-0 opacity-70 transition-opacity group-hover:opacity-100 sm:size-4"
											aria-hidden="true"
										>
											<path d="m9 18 6-6-6-6" />
										</svg>
										{link.label}
									</a>
								</li>
							))
						}
					</ul>

					<h3
						class="mt-8 mb-4 text-[0.8125rem] font-bold tracking-[0.08em] uppercase text-white sm:mt-10 sm:mb-5 sm:text-sm"
						data-aos="flip-up"
					>
						Enlaces
					</h3>
					<ul class="flex flex-col gap-2.5 sm:gap-3">
						{
							externalLinks.map((link, index) => (
								<li>
									<a
										href={link.href}
										target="_blank"
										rel="noopener noreferrer"
										class="group inline-flex items-center gap-1 text-sm font-semibold text-white/80 transition-colors duration-200 hover:text-white sm:text-[0.9375rem]"
										data-aos="fade"
										data-aos-duration="500"
										data-aos-delay={index * 300}
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											class="size-3.5 shrink-0 opacity-70 transition-opacity group-hover:opacity-100 sm:size-4"
											aria-hidden="true"
										>
											<path d="m9 18 6-6-6-6" />
										</svg>
										{link.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>

				<!-- Atención -->
				<div class="lg:col-span-3">
					<h3
						class="mb-4 text-[0.8125rem] font-bold tracking-[0.08em] uppercase text-white sm:mb-5 sm:text-sm"
						data-aos="flip-up"
					>
						Atención
					</h3>
					<ul class="space-y-4 text-sm font-medium text-white/80 sm:text-base">
						{
							ADDRESS && MAP_URL && (
								<li>
									<a
										href={MAP_URL}
										target="_blank"
										rel="noopener noreferrer"
										class="group flex items-start gap-3 transition-opacity duration-200 hover:opacity-85"
										data-aos="fade"
										data-aos-duration="500"
										data-aos-delay="400"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											class="mt-1 h-4.5 w-4.5 shrink-0 text-white/90"
											aria-hidden="true"
										>
											<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
											<circle cx="12" cy="10" r="3" />
										</svg>
										<span>
											<span
												class="mb-0.5 block text-xs font-bold tracking-[0.06em] uppercase text-white/90"
												>Dirección</span>
											<span class="block leading-normal">{ADDRESS}</span>
										</span>
									</a>
								</li>
							)
						}
						{
							SCHEDULES && (
								<li
									class="flex items-start gap-3"
									data-aos="fade"
									data-aos-duration="500"
									data-aos-delay="600"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										class="mt-1 h-4.5 w-4.5 shrink-0 text-white/90"
										aria-hidden="true"
									>
										<circle cx="12" cy="12" r="10" />
										<polyline points="12 6 12 12 16 14" />
									</svg>
									<span>
										<span
											class="mb-0.5 block text-xs font-bold tracking-[0.06em] uppercase text-white/90"
											>Horarios</span>
										<span class="block leading-normal">{SCHEDULES}</span>
									</span>
								</li>
							)
						}
					</ul>
				</div>

				<!-- Contacto -->
				<div class="lg:col-span-3">
					<h3
						class="mb-4 text-[0.8125rem] font-bold tracking-[0.08em] uppercase text-white sm:mb-5 sm:text-sm"
						data-aos="flip-up"
					>
						Contacto
					</h3>
					<ul class="space-y-4 text-sm font-medium text-white/80 sm:text-base">
						{
							phoneHref && PHONE_FORMAT && (
								<li>
									<a
										href={phoneHref}
										class="flex items-start gap-3 transition-opacity duration-200 hover:opacity-85"
										data-aos="fade"
										data-aos-duration="500"
										data-aos-delay="400"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											class="mt-1 h-4.5 w-4.5 shrink-0 text-white/90"
											aria-hidden="true"
										>
											<path
												d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
											></path>
										</svg>
										<span>
											<span
												class="mb-0.5 block text-xs font-bold tracking-[0.06em] uppercase text-white/90"
												>Teléfono</span>
											<span class="block leading-normal">{PHONE_FORMAT}</span>
										</span>
									</a>
								</li>
							)
						}
						{
							whatsappHref && whatsappFormat && (
								<li>
									<a
										href={whatsappHref}
										target="_blank"
										rel="noopener noreferrer"
										class="flex items-start gap-3 transition-opacity duration-200 hover:opacity-85"
										data-aos="fade"
										data-aos-duration="500"
										data-aos-delay="600"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="currentColor"
											class="mt-1 h-4.5 w-4.5 shrink-0 text-white/90"
											aria-hidden="true"
										>
											<path
												d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
											></path>
										</svg>
										<span>
											<span
												class="mb-0.5 block text-xs font-bold tracking-[0.06em] uppercase text-white/90"
												>WhatsApp</span>
											<span class="block leading-normal">{whatsappFormat}</span>
										</span>
									</a>
								</li>
							)
						}
						{
							emailHref && EMAIL && (
								<li>
									<a
										href={emailHref}
										class="flex items-start gap-3 transition-opacity duration-200 hover:opacity-85"
										data-aos="fade"
										data-aos-duration="500"
										data-aos-delay="800"
									>
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											class="mt-1 h-4.5 w-4.5 shrink-0 text-white/90"
											aria-hidden="true"
										>
											<rect width="20" height="16" x="2" y="4" rx="2" />
											<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
										</svg>
										<span>
											<span
												class="mb-0.5 block text-xs font-bold tracking-[0.06em] uppercase text-white/90"
												>Correo</span>
											<span class="block leading-normal break-all">{EMAIL}</span>
										</span>
									</a>
								</li>
							)
						}
					</ul>
				</div>
			</div>

			<div
				class="mt-10 flex flex-col gap-3 border-t border-white/15 pt-6 sm:mt-12 sm:flex-row sm:items-center sm:justify-between sm:gap-4"
				data-aos="flip-right"
			>
				<p
					class="text-xs font-medium text-white/70 sm:text-sm"
				>
					Desarrollado por{" "}
					<a
						href="https://tresvecestres.com.ar/"
						target="_blank"
						rel="noopener noreferrer"
						class="text-white/90 underline decoration-white/30 underline-offset-2 transition-colors hover:text-white hover:decoration-white/60"
					>
						Tres Veces Tres
					</a>
				</p>
				<p
					class="text-xs font-semibold text-white/85 sm:text-right sm:text-sm"
				>
					&copy; {new Date().getFullYear()} LA UNIÓN S.R.L.
				</p>
			</div>
		</div>
	</div>
</footer>
