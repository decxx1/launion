---

<section class="relative overflow-hidden pt-28 pb-12 sm:pt-32 sm:pb-16 lg:pt-36 lg:pb-20">
	<!-- Rombo de fondo (más grande y desplazado a la derecha) -->
	<div
		class="pointer-events-none absolute inset-0 overflow-hidden"
		aria-hidden="true"
	>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt="rombo de fondo azul"
			loading="lazy"
			class="absolute top-[72%] left-0 lg:hidden h-[200vh] sm:h-[250vh] w-auto max-w-none translate-x-[-70%] -translate-y-1/2 select-none sm:top-[66%] sm:left-10"
		/>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt="rombo de fondo azul"
			loading="lazy"
			class="absolute top-1/2 left-0 hidden lg:block h-[300vh] w-auto max-w-none translate-x-[-40%] 2xl:translate-x-[-34%] -translate-y-1/2 select-none"
		/>
	</div>

	<ArrowImageBanner
		id="puntos-de-venta-banner"
		image="/images/punto-venta/puntos-de-venta.webp"
		imageAlt="Mapa de Argentina y colectivo de LA UNION S.R.L."
		align="end"
	>
		<h1
			class="text-sm xs:text-lg sm:text-xl md:text-2xl xl:text-4xl"
			data-aos="fade-left"
			data-aos-duration="800"
			data-aos-delay="200"
		>
			Conocé nuestros puntos de venta y entrega en el país.
		</h1>
	</ArrowImageBanner>

	<div class="relative z-10 container mx-auto mt-10 max-w-7xl px-4 sm:mt-12 lg:mt-16">
		{
			provinces.map((province, provinceIndex) => (
				<section class="mb-10 last:mb-0 sm:mb-12 lg:mb-14">
					<div
						class="relative mb-6 inline-flex h-12 min-w-56 items-center sm:mb-8 sm:h-14 sm:min-w-64 md:min-w-80 lg:min-w-96"
						data-aos="fade-right"
						data-aos-duration="800"
						data-aos-delay={provinceIndex * 100}
					>
						<img
							src="/images/shapes/arrow-right-large-blue.svg"
							alt="flecha grande azul para el punto de venta"
							class="absolute inset-0 h-full w-full object-fill"
							aria-hidden="true"
							loading="lazy"
						/>
						<h2
							class="relative z-10 pl-6 pr-14 text-xl font-bold text-white sm:pl-8 sm:pr-16 sm:text-2xl md:text-3xl"
						>
							{province.name}
						</h2>
					</div>

					<ul
						class="grid grid-cols-1 gap-x-8 gap-y-6 sm:gap-x-10 sm:gap-y-7 md:grid-cols-2 lg:gap-x-14"
					>
						{
							province.locations.map((location, index) => (
								<li
									class="flex items-start gap-3 sm:gap-4"
									data-aos={index % 2 === 0 ? "fade-right" : "fade-left"}
									data-aos-duration="800"
									data-aos-delay={100 + index * 75}
								>
									<img
										src="/images/icons/icon-disc.svg"
										alt="icono de disco para el punto de venta"
										class="mt-1.5 size-3 shrink-0 sm:mt-2 sm:size-3.5"
										aria-hidden="true"
										loading="lazy"
									/>
									<div class="space-y-0.5 text-sm text-gray-900 sm:text-base">
										<p class="font-bold">{location.title}</p>
										{
											location.details.map((detail) => (
												<p class="font-medium">{detail}</p>
											))
										}
									</div>
								</li>
							))
						}
					</ul>
				</section>
			))
		}
	</div>
</section>
