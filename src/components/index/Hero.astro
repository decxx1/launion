---
const ticketUrl = "https://abmws.com.ar/luweb-nuebus/sale/paso1.php";

const heroSlides = [
	{
		alt: "Colectivo de LA UNION S.R.L. en Buenos Aires",
		desktop: "/images/home/hero-buenos-aires.webp",
		mobile: "/images/home/hero-buenos-aires-mobile.webp",
	},
	{
		alt: "Colectivo de LA UNION S.R.L. en Mendoza",
		desktop: "/images/home/hero-mendoza.webp",
		mobile: "/images/home/hero-mendoza-mobile.avif",
	},
	{
		alt: "Colectivo de LA UNION S.R.L. en la región de Mendoza",
		desktop: "/images/home/hero-mendoza-vid.webp",
		mobile: "/images/home/hero-mendoza-vid-mobile.webp",
	},
];
---

<section class="relative h-screen w-full overflow-hidden">
	<!-- Carrusel de imágenes de fondo -->
	<div class="absolute inset-0" aria-hidden="true">
		{
			heroSlides.map((slide, index) => (
				<>
					<img
						src={slide.mobile}
						alt={slide.alt}
						data-slide-index={index}
						class:list={[
							"hero-slide absolute inset-0 h-full w-full object-cover object-center lg:hidden",
							index === 0 && "is-active",
						]}
						fetchpriority={index === 0 ? "high" : undefined}
						loading={index === 0 ? "eager" : "lazy"}
						decoding="async"
					/>
					<img
						src={slide.desktop}
						alt={slide.alt}
						data-slide-index={index}
						class:list={[
							"hero-slide absolute inset-0 hidden h-full w-full object-cover object-center lg:block",
							index === 0 && "is-active",
						]}
						fetchpriority={index === 0 ? "high" : undefined}
						loading={index === 0 ? "eager" : "lazy"}
						decoding="async"
					/>
				</>
			))
		}
	</div>

	<!-- Rombo -->
	<div
		class="pointer-events-none absolute inset-0 overflow-hidden"
		aria-hidden="true"
	>
		<img
			src="/images/shapes/shape-diamond.svg"
			alt="Figura geométrica en forma de rombo"
			loading="lazy"
			class="absolute top-[72%] left-0 sm:left-10 h-[110vh] w-auto max-w-none translate-x-[-70%] -translate-y-1/2 select-none sm:top-[66%] sm:h-[115vh] lg:hidden"
		/>
		<img
			src="/images/shapes/shape-diamond.svg"
			loading="lazy"
			alt="Figura geométrica en forma de rombo"
			class="absolute top-1/2 left-0 hidden h-[165vh] w-auto max-w-none translate-x-[-56%] -translate-y-1/2 select-none lg:block xl:h-[175vh] xl:translate-x-[-58%] 2xl:translate-x-[-46%]"
		/>
	</div>

	<!-- Logo desktop (se oculta al scrollear: el header pill lo reemplaza) -->
	<a
		href="/"
		class="hero-logo absolute top-8 left-8 z-20 hidden transition-opacity duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] lg:block xl:top-16 xl:left-12 2xl:top-20 2xl:left-32"
		aria-label="LA UNION S.R.L. - Inicio"
	>
		<img
			src="/images/logos/logo.svg"
			loading="lazy"
			alt="LA UNION S.R.L."
			class="h-auto w-32 lg:w-48 xl:w-54 2xl:w-56"
		/>
	</a>

	<!-- Texto principal -->
	<div
		class="absolute z-20 flex flex-col text-white text-right
			bottom-[24%] left-6 max-w-[85%]
			sm:bottom-[32%]
			lg:top-1/2 lg:bottom-auto lg:left-20 lg:max-w-md lg:translate-y-[-50%]
			xl:left-16 xl:max-w-lg 2xl:left-28"
	>
		<h1 class="font-bold tracking-tight">
			<span class="relative block text-4xl sm:text-5xl lg:text-7xl xl:text-8xl">
				<svg class="absolute top-0 xl:top-1 left-12 sm:left-7 lg:left-8 xl:left-12 w-6 sm:w-8 lg:w-9 xl:w-12" xmlns="http://www.w3.org/2000/svg" id="Capa_2" data-name="Capa 2" viewBox="0 0 50.34 22.68"><path id="LANDING" fill="#fff" d="M25.18 7.22C14.6 7.22 5.3 13.38 0 22.68v-7.23C5.3 6.16 14.6 0 25.18 0s19.85 6.14 25.16 15.4v7.23C45.03 13.37 35.75 7.22 25.18 7.22"/></svg>
				unimos
			</span>
			<span class="block text-3xl sm:text-4xl lg:text-5xl xl:text-6xl">
				destinos
			</span>
		</h1>
		<p class="mt-3 text-base font-medium sm:text-lg lg:mt-5 lg:text-2xl xl:text-3xl tracking-wide xl:tracking-widest">
			Acercamos historias
		</p>
	</div>

	<!-- CTA -->
	<div
		class="absolute -right-2 bottom-22 z-30 w-80 sm:w-120 lg:w-[48%] xl:w-[44%] 2xl:w-180"
	>
		<div class="relative w-full">
			<img
				src="/images/shapes/shape-arrow-left.svg"
				alt="Figura geométrica en forma de flecha"
				loading="lazy"
				class="block h-full w-full"
				aria-hidden="true"
			/>

			<div
				class="absolute inset-0 flex flex-col justify-center gap-1.5 py-2.5 pl-16 pr-0
					sm:gap-2 sm:py-3 sm:pl-20
					lg:gap-2 lg:py-4 lg:pl-[12%]"
			>
				<p
					class="max-w-64 text-base leading-tight font-bold text-white italic
						sm:max-w-none sm:text-lg lg:text-2xl xl:text-3xl"
				>
					¡Comprá tus pasajes ahora!
				</p>

				<a
					href={ticketUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="group relative ml-auto block w-full transition-opacity hover:opacity-95"
				>
					<img
						src="/images/shapes/shape-arrow-left-white.svg"
						alt="Figura geométrica en forma de flecha para el botón"
						class="block h-full w-full"
						aria-hidden="true"
						loading="lazy"
					/>
					<span
						class="absolute inset-0 flex items-center justify-start 
						gap-2.5 pr-5 pl-[12%]
						sm:gap-3 sm:pr-6 sm:pl-[11%]
						lg:gap-3 lg:pr-7 lg:pl-[10%]"
					>
						<span
							class="text-xl font-extrabold tracking-wide text-launion sm:text-2xl lg:text-[1.65rem] xl:text-[1.85rem]"
						>
							CLICK ACÁ
						</span>
						<img
							src="/images/icons/clickIcon.svg"
							alt="Icono de clic"
							loading="lazy"
							class="size-9 shrink-0 sm:size-10 lg:size-11 xl:size-12"
						/>
					</span>
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-slide {
		opacity: 0;
		transition: opacity 1.2s ease-in-out;
	}

	.hero-slide.is-active {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-slide {
			transition: none;
		}
	}
</style>

<script>
	const SLIDE_INTERVAL_MS = 5000;

	function initHeroCarousel() {
		const slides = Array.from(
			document.querySelectorAll<HTMLImageElement>(".hero-slide"),
		);
		const slideCount = new Set(
			slides.map((slide) => slide.dataset.slideIndex),
		).size;
		if (slideCount <= 1) return;

		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;
		if (prefersReducedMotion) return;

		let currentIndex = 0;

		const setActiveSlide = (index: number) => {
			slides.forEach((slide) => {
				const slideIndex = Number(slide.dataset.slideIndex);
				slide.classList.toggle("is-active", slideIndex === index);
			});
		};

		window.setInterval(() => {
			currentIndex = (currentIndex + 1) % slideCount;
			setActiveSlide(currentIndex);
		}, SLIDE_INTERVAL_MS);
	}

	initHeroCarousel();
</script>
