---
const ticketUrl = "https://launionsrl.com.ar";
---

<section class="relative h-screen w-full overflow-hidden">
	<!-- Imagen de fondo -->
	<img
		src="/images/home/hero.png"
		alt="Colectivo de LA UNION S.R.L. en la ciudad"
		class="absolute inset-0 h-full w-full object-cover object-center"
		fetchpriority="high"
	/>

	<!-- Formas geométricas — Desktop -->
	<div class="pointer-events-none absolute inset-0 hidden lg:block" aria-hidden="true">
		<svg
			class="absolute inset-0 h-full w-full"
			viewBox="0 0 1440 900"
			preserveAspectRatio="none"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path
				d="M0,0 L0,900 L560,900 C680,900 710,520 760,450 C710,380 680,0 520,0 Z"
				fill="#c5cdd4"
			></path>
			<path
				d="M0,0 L0,900 L540,900 C660,900 690,520 740,450 C690,380 660,0 500,0 Z"
				fill="#096db7"
			></path>
			<path
				d="M0,0 L0,900 L520,900 C640,900 670,520 720,450 C670,380 640,0 480,0 Z"
				fill="#0b5886"
			></path>
		</svg>
	</div>

	<!-- Formas geométricas — Mobile -->
	<div class="pointer-events-none absolute inset-0 lg:hidden" aria-hidden="true">
		<svg
			class="absolute inset-0 h-full w-full"
			viewBox="0 0 390 844"
			preserveAspectRatio="none"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path
				d="M0,420 L0,844 L390,844 L390,620 C320,580 280,500 260,420 Z"
				fill="#c5cdd4"
			></path>
			<path
				d="M0,430 L0,844 L390,844 L390,630 C310,590 270,510 255,430 Z"
				fill="#096db7"
			></path>
			<path
				d="M0,440 L0,844 L390,844 L390,640 C300,600 260,520 250,440 Z"
				fill="#0b5886"
			></path>
			<!-- Franjas decorativas inferiores -->
			<path d="M0,800 L120,844 L0,844 Z" fill="#096db7"></path>
			<path d="M0,820 L80,844 L0,844 Z" fill="#e8ecef"></path>
		</svg>
	</div>

	<!-- Logo desktop -->
	<a
		href="/"
		class="absolute top-8 left-8 z-20 hidden lg:block xl:left-12"
		aria-label="LA UNION S.R.L. - Inicio"
	>
		<img
			src="/images/logos/logo.svg"
			alt="LA UNION S.R.L."
			class="h-14 w-auto xl:h-16"
			width="200"
			height="86"
		/>
	</a>

	<!-- Texto principal -->
	<div
		class="absolute z-20 flex flex-col text-white
			bottom-[38%] left-6 max-w-[85%]
			lg:top-1/2 lg:bottom-auto lg:left-10 lg:max-w-md lg:-translate-y-1/3
			xl:left-16 xl:max-w-lg"
	>
		<h1 class="leading-[0.95] font-bold tracking-tight">
			<span class="relative block text-[2.6rem] sm:text-5xl lg:text-6xl xl:text-7xl">
				<svg
					class="absolute -top-3 left-0 h-3 w-10 sm:-top-4 sm:h-4 sm:w-12 lg:-top-5 lg:h-5 lg:w-14"
					viewBox="0 0 56 12"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					aria-hidden="true"
				>
					<path
						d="M4 10 C14 2, 28 2, 52 10"
						stroke="white"
						stroke-width="2.5"
						stroke-linecap="round"
						fill="none"
					></path>
				</svg>
				unimos
			</span>
			<span class="block text-[2.6rem] sm:text-5xl lg:text-6xl xl:text-7xl">
				destinos
			</span>
		</h1>
		<p class="mt-3 text-base font-medium sm:text-lg lg:mt-5 lg:text-xl">
			Acercamos historias
		</p>
	</div>

	<!-- CTA -->
	<div
		class="absolute right-0 bottom-0 left-0 z-20 flex items-end justify-end
			lg:left-auto lg:w-[55%] xl:w-[50%]"
	>
		<!-- Fondo CTA desktop -->
		<svg
			class="absolute right-0 bottom-0 hidden h-auto w-full lg:block"
			viewBox="0 0 800 200"
			preserveAspectRatio="none"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
		>
			<path
				d="M120,0 L800,0 L800,200 L0,200 L80,100 Z"
				fill="#0b5886"
			></path>
		</svg>

		<!-- Fondo CTA mobile -->
		<div
			class="absolute right-0 bottom-0 left-0 h-36 bg-launion lg:hidden"
			aria-hidden="true"
		></div>

		<div
			class="relative flex w-full flex-col items-end gap-3 px-5 py-5
				sm:flex-row sm:items-center sm:justify-end sm:gap-6 sm:px-8 sm:py-6
				lg:px-10 lg:py-8"
		>
			<p
				class="text-right text-sm font-bold text-white sm:text-base lg:text-lg xl:text-xl"
			>
				¡Comprá tus pasajes ahora!
			</p>

			<a
				href={ticketUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="group flex shrink-0 items-center gap-2 bg-white pr-3 pl-6
					[clip-path:polygon(12%_0%,100%_0%,100%_100%,0%_100%)]
					transition-opacity hover:opacity-90
					sm:gap-3 sm:pr-4 sm:pl-8
					lg:[clip-path:polygon(10%_0%,100%_0%,100%_100%,0%_100%)]"
			>
				<span
					class="py-3 text-sm font-extrabold tracking-wide text-launion sm:py-3.5 sm:text-base"
				>
					CLICK ACÁ
				</span>
				<img
					src="/images/icons/clickIcon.svg"
					alt=""
					class="h-9 w-9 sm:h-10 sm:w-10"
					width="40"
					height="36"
				/>
			</a>
		</div>
	</div>
</section>
