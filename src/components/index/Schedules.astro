---
import ArrowImageBanner from "@/components/ArrowImageBanner.astro";

const routes = [
	{
		label: "LOCAL",
		href: "/PDF/Horario Invierno 20-07-26.pdf",
	},
	{
		label: "URBANO PERIFÉRICO",
		href: "/PDF/Horario Periferia Alvear desde 20-07-26.pdf",
	},
	{
		label: "SAN RAFAEL BOWEN",
		href: "/PDF/Horario San Rafael desde 20-07-26.pdf",
	},
	{
		label: "MENDOZA BOWEN",
		href: "/PDF/Horario-Linea-Mendoza-scaled.jpg",
	},
	{
		label: "SAN RAFAEL BUENOS AIRES",
		href: "/PDF/Linea_SanRafael_BsAs_Horario_.pdf",
	},
	{
		label: "MENDOZA BUENOS AIRES",
		href: "/PDF/Linea_Mendoza_BsAs_Horario.pdf",
	},
];
---

<section class="relative overflow-hidden pt-28 pb-10 sm:pt-32 sm:pb-12 lg:pt-36 lg:pb-16">
	<!-- Rombo de fondo (lado izquierdo) -->
	<div
		class="pointer-events-none absolute inset-0 overflow-hidden"
		aria-hidden="true"
	>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt="figura de rombo para el fondo"
			loading="lazy"
			class="absolute top-[72%] left-0 h-[110vh] w-auto max-w-none translate-x-[-70%] -translate-y-1/2 select-none sm:top-[66%] sm:left-10 sm:h-[115vh] lg:hidden"
		/>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt="figura de rombo para el fondo"
			loading="lazy"
			class="absolute top-1/2 left-0 hidden h-[165vh] w-auto max-w-none translate-x-[-56%] -translate-y-1/2 select-none lg:block xl:h-[175vh] xl:translate-x-[-58%] 2xl:translate-x-[-46%]"
		/>
	</div>

	<ArrowImageBanner
		id="horarios-banner"
		image="/images/home/schedules.webp"
		imageAlt="Colectivo de LA UNION S.R.L."
		align="startLeft"
		imageClass="object-cover object-[center_40%] sm:object-center"
	>
		<h1
			class="text-left text-lg sm:text-2xl md:text-3xl xl:text-4xl"
			data-aos="fade-left"
			data-aos-duration="800"
			data-aos-delay="200"
		>
			Descargá los horarios <br class="hidden sm:block" />
			de nuestras líneas <br class="hidden sm:block" />
			de colectivo
		</h1>
	</ArrowImageBanner>

	<div class="relative z-10 container max-w-7xl mx-auto w-full px-4">
		<!-- Botones en rombo -->
		<div
			class="my-16 sm:my-10 md:my-16 lg:my-20 grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-6 gap-3 items-center justify-items-center pb-2 lg:pb-0"
		>
			{
				routes.map(({ label, href }, index) => (
					<a
						href={href}
						download
						class="schedule-route-btn group relative flex w-32 sm:w-44 xl:w-full shrink-0 snap-center flex-col items-center justify-center rounded-sm outline-none focus-visible:ring-2 focus-visible:ring-launion-light focus-visible:ring-offset-2"
						data-aos="fade-up"
						data-aos-duration="600"
						data-aos-delay={index * 100}
					>
						<div class="schedule-route-inner relative aspect-226/217 w-full">
							<img
								src="/images/shapes/shape-button-diamond.svg"
								alt="figura de rombo para el botón"
								class="schedule-route-diamond absolute inset-0 h-full w-full"
								aria-hidden="true"
								loading="lazy"
							/>
							<span
								class="absolute inset-0 flex flex-col items-center justify-start pr-3 pl-2 pt-6 sm:pt-8 lg:pt-6 xl:pt-8 gap-2 sm:gap-3 md:gap-4 sm:pl-2 sm:pr-4"
							>
								<img
									src="/images/icons/icon-bus.svg"
									alt="icono de colectivo para horarios"
									class="schedule-route-icon size-7 sm:size-10 xl:size-14"
									aria-hidden="true"
									loading="lazy"
								/>
								<span class="schedule-route-label text-center text-[0.6rem] uppercase sm:text-xs 2xl:text-sm px-2 leading-tight font-bold tracking-wide text-white">
									{label}
								</span>
							</span>
						</div>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.schedule-route-inner {
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.schedule-route-btn:hover .schedule-route-inner,
	.schedule-route-btn:focus-visible .schedule-route-inner {
		transform: scale(1.06) translateY(-4px);
	}

	.schedule-route-btn:active .schedule-route-inner {
		transform: scale(0.98) translateY(0);
	}

	.schedule-route-diamond {
		transition:
			filter 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.schedule-route-btn:hover .schedule-route-diamond,
	.schedule-route-btn:focus-visible .schedule-route-diamond {
		filter: brightness(1.12) saturate(1.08)
			drop-shadow(0 12px 22px rgba(11, 88, 134, 0.42));
		transform: translateY(-2px);
	}

	.schedule-route-icon {
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.schedule-route-btn:hover .schedule-route-icon,
	.schedule-route-btn:focus-visible .schedule-route-icon {
		transform: scale(1.12) translateY(-3px);
	}

	.schedule-route-label {
		transition: letter-spacing 0.35s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.schedule-route-btn:hover .schedule-route-label,
	.schedule-route-btn:focus-visible .schedule-route-label {
		letter-spacing: 0.08em;
	}

	@media (prefers-reduced-motion: reduce) {
		.schedule-route-inner,
		.schedule-route-diamond,
		.schedule-route-icon,
		.schedule-route-label {
			transition: none;
		}

		.schedule-route-btn:hover .schedule-route-inner,
		.schedule-route-btn:focus-visible .schedule-route-inner,
		.schedule-route-btn:active .schedule-route-inner {
			transform: none;
		}

		.schedule-route-btn:hover .schedule-route-diamond,
		.schedule-route-btn:focus-visible .schedule-route-diamond {
			filter: brightness(1.08);
			transform: none;
		}

		.schedule-route-btn:hover .schedule-route-icon,
		.schedule-route-btn:focus-visible .schedule-route-icon {
			transform: none;
		}

		.schedule-route-btn:hover .schedule-route-label,
		.schedule-route-btn:focus-visible .schedule-route-label {
			letter-spacing: inherit;
		}
	}
</style>
