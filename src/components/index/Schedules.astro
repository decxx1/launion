---
const routes = [
	{ label: "LOCAL", href: "#" },
	{ label: "URBANO PERIFÉRICO", href: "#" },
	{ label: "SAN RAFAEL BOWEN", href: "#" },
	{ label: "MENDOZA BOWEN", href: "#" },
	{ label: "SAN RAFAEL BUENOS AIRES", href: "#" },
	{ label: "MENDOZA BUENOS AIRES", href: "#" },
];
---

<section class="relative overflow-hidden bg-white py-10 sm:py-12 lg:py-16">
	<!-- Rombo de fondo (lado izquierdo) -->
	<div
		class="pointer-events-none absolute inset-0 overflow-hidden"
		aria-hidden="true"
	>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt="figura de rombo para el fondo"
			loading="lazy"
			class="absolute top-[72%] left-0 h-[110vh] w-auto max-w-none translate-x-[-70%] -translate-y-1/2 select-none sm:top-[66%] sm:left-10 sm:h-[115vh] lg:hidden"
		/>
		<img
			src="/images/shapes/shape-diamond-bg.svg"
			alt="figura de rombo para el fondo"
			loading="lazy"
			class="absolute top-1/2 left-0 hidden h-[165vh] w-auto max-w-none translate-x-[-56%] -translate-y-1/2 select-none lg:block xl:h-[175vh] xl:translate-x-[-58%] 2xl:translate-x-[-46%]"
		/>
	</div>

	<div class="relative z-10 container max-w-7xl mx-auto w-full px-4">
		<!-- Título -->
		<div
			class="flex items-center justify-center gap-3 rounded-tl-[3.5rem] rounded-br-[3.5rem] bg-launion px-5 py-3.5 sm:gap-4 sm:px-7 sm:py-4 lg:px-8"
		>
			<img
				src="/images/icons/icon-clock.svg"
				alt="icono de reloj para horarios"
				class="size-9 shrink-0 sm:size-10 lg:size-11"
				aria-hidden="true"
				loading="lazy"
			/>
			<h2
				class="text-base lg:text-lg xl:text-xl font-semibold sm:font-bold leading-tight text-white"
			>
				Descargá los horarios de nuestras líneas de colectivo
			</h2>
		</div>

		<!-- Botones en rombo -->
		<div
			class="my-16 sm:my-10 md:my-16 lg:my-20 grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-6 gap-3 items-center justify-items-center pb-2 lg:pb-0"
		>
			{
				routes.map(({ label, href }) => (
					<a
						href={href}
						class="group relative flex w-32 sm:w-44 xl:w-full shrink-0 snap-center flex-col items-center justify-center transition-opacity hover:opacity-90"
					>
						<div class="relative aspect-226/217 w-full">
							<img
								src="/images/shapes/shape-button-diamond.svg"
								alt="figura de rombo para el botón"
								class="absolute inset-0 h-full w-full"
								aria-hidden="true"
								loading="lazy"
							/>
							<span
								class="absolute inset-0 flex flex-col items-center justify-start pr-3 pl-2 pt-6 sm:pt-8 lg:pt-6 xl:pt-8 gap-2 sm:gap-3 md:gap-4 sm:pl-2 sm:pr-4"
							>
								<img
									src="/images/icons/icon-bus.svg"
									alt="icono de colectivo para horarios"
									class="size-7 sm:size-10 xl:size-14"
									aria-hidden="true"
									loading="lazy"
								/>
								<span class="text-center text-[0.6rem] uppercase sm:text-xs 2xl:text-sm px-2 leading-tight font-bold tracking-wide text-white">
									{label}
								</span>
							</span>
						</div>
					</a>
				))
			}
		</div>
	</div>

	<!-- Imagen del colectivo -->
	<div class="relative z-10 mr-10 md:mr-20 lg:mr-32 xl:mr-56">
		<div class="schedules-image-clip relative aspect-700/250 sm:aspect-855/210 w-full overflow-hidden">
			<img
				src="/images/home/schedules.webp"
				alt="Colectivo de LA UNION S.R.L."
				class="absolute inset-0 h-full w-full object-cover object-[center_40%] sm:object-center"
				loading="lazy"
			/>
			<div
				class="pointer-events-none absolute inset-0 bg-linear-to-r from-launion from-0% via-launion/20 via-15% sm:via-35% to-transparent to-100%"
				aria-hidden="true"
			/>
		</div>
	</div>
</section>
<svg width="0" height="0" style="position:absolute">
	<defs>
	  <clipPath id="flecha-clip-base" clipPathUnits="objectBoundingBox">
		<path d="M 0 0 L 0.83 0 Q 0.84 0 0.85 0.03 L 0.975 0.40 Q 1 0.5 0.975 0.60 L 0.85 0.97 Q 0.84 1 0.83 1 L 0 1 Z" />
	  </clipPath>
	  <clipPath id="flecha-clip-sm" clipPathUnits="objectBoundingBox">
		<path d="M 0 0 L 0.85 0 Q 0.86 0 0.87 0.03 L 0.975 0.40 Q 1 0.5 0.975 0.60 L 0.87 0.97 Q 0.86 1 0.85 1 L 0 1 Z" />
	  </clipPath>
	  <clipPath id="flecha-clip-lg" clipPathUnits="objectBoundingBox">
		<path d="M 0 0 L 0.87 0 Q 0.88 0 0.89 0.03 L 0.975 0.40 Q 1 0.5 0.975 0.60 L 0.89 0.97 Q 0.88 1 0.87 1 L 0 1 Z" />
	  </clipPath>
	</defs>
  </svg>
<style>
	.schedules-image-clip {
    clip-path: url(#flecha-clip-base);
}
@media (min-width: 640px) {
    .schedules-image-clip {
        clip-path: url(#flecha-clip-sm);
    }
}
@media (min-width: 1024px) {
    .schedules-image-clip {
        clip-path: url(#flecha-clip-lg);
    }
}
</style>
