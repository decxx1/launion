---
const navLinks = [
	{ label: "INICIO", href: "/" },
	{ label: "NOSOTROS", href: "/nosotros" },
	{ label: "SERVICIOS", href: "/servicios" },
	{ label: "ENCOMIENDAS", href: "/encomiendas" },
	{ label: "PUNTOS DE VENTA", href: "/puntos-de-venta" },
	{ label: "CONTACTO", href: "/contacto" },
];

interface Props {
	/** En páginas sin hero, el header arranca ya en estado scrolleado */
	forceScrolled?: boolean;
}

const { forceScrolled = false } = Astro.props;

const currentPath =
	Astro.url.pathname.replace(/\/$/, "") || "/";

function isActiveLink(href: string): boolean {
	if (href === "/") return currentPath === "/";
	return currentPath === href;
}
---

<!-- Desktop: pestaña superior derecha → dos islas pill (logo + nav) al scrollear -->
<div class="pointer-events-none fixed inset-x-0 top-0 z-50 hidden h-0 lg:block">
	<header
		id="desktop-header"
		class="group/nav pointer-events-auto absolute top-0 left-full z-50 -translate-x-full transition-[top,left,transform] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform data-scrolled:top-4 data-scrolled:left-[calc(50%-2.5rem)] data-scrolled:-translate-x-1/2"
		data-force-scrolled={forceScrolled ? "" : undefined}
		data-scrolled={forceScrolled ? "" : undefined}
	>
		<div
			class="flex items-center gap-0 rounded-bl-[4.5rem] bg-white py-5 pr-8 pl-10 transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] xl:py-6 xl:pr-12 xl:pl-28 group-data-scrolled/nav:gap-3 group-data-scrolled/nav:rounded-none group-data-scrolled/nav:bg-transparent group-data-scrolled/nav:p-0 group-data-scrolled/nav:xl:gap-4"
		>
			<a
				href="/"
				class="header-logo block max-w-0 shrink-0 overflow-hidden opacity-0 transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-data-scrolled/nav:max-w-[18rem] group-data-scrolled/nav:rounded-full group-data-scrolled/nav:bg-white group-data-scrolled/nav:px-5 group-data-scrolled/nav:py-3 group-data-scrolled/nav:opacity-100 group-data-scrolled/nav:shadow-[0_10px_40px_-12px_rgba(11,88,134,0.28)] group-data-scrolled/nav:xl:max-w-[20rem] group-data-scrolled/nav:xl:px-6 group-data-scrolled/nav:xl:py-3.5"
				aria-label="LA UNION S.R.L. - Inicio"
				tabindex={forceScrolled ? 0 : -1}
				aria-hidden={forceScrolled ? "false" : "true"}
			>
				<img
					src="/images/logos/logo-horizontal-azul.svg"
					alt="Logo LA UNION S.R.L."
					class="h-auto w-44 xl:w-52"
					width="522"
					height="35"
					loading="lazy"
				/>
			</a>
			<nav
				aria-label="Navegación principal"
				class="transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-data-scrolled/nav:rounded-full group-data-scrolled/nav:bg-white group-data-scrolled/nav:px-8 group-data-scrolled/nav:py-3.5 group-data-scrolled/nav:shadow-[0_10px_40px_-12px_rgba(11,88,134,0.28)] group-data-scrolled/nav:xl:px-10 group-data-scrolled/nav:xl:py-4"
			>
				<ul
					class="flex items-center justify-center gap-4 text-sm font-semibold tracking-wide whitespace-nowrap text-black transition-[gap,font-size] duration-500 xl:gap-6 xl:text-base 2xl:gap-7 2xl:text-lg group-data-scrolled/nav:gap-3.5 group-data-scrolled/nav:text-[0.8125rem] group-data-scrolled/nav:xl:gap-5 group-data-scrolled/nav:xl:text-sm group-data-scrolled/nav:2xl:gap-5 group-data-scrolled/nav:2xl:text-base"
				>
					{
						navLinks.map((link) => {
							const active = isActiveLink(link.href);
							return (
								<li>
									<a
										href={link.href}
										class:list={[
											"group/link relative inline-block pb-1.5 text-black transition-colors duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] hover:text-launion",
											active && "text-launion",
										]}
										aria-current={active ? "page" : undefined}
									>
										{link.label}
										<svg
											class="pointer-events-none absolute -bottom-px left-0 h-2 w-full overflow-visible text-launion"
											viewBox="0 0 100 8"
											preserveAspectRatio="none"
											aria-hidden="true"
										>
											<path
												d="M1,6 Q50,1 99,6"
												fill="none"
												stroke="currentColor"
												stroke-width="2.5"
												stroke-linecap="round"
												pathLength="100"
												class:list={[
													"[stroke-dasharray:100] [stroke-dashoffset:100] transition-[stroke-dashoffset] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover/link:[stroke-dashoffset:0]",
													active && "[stroke-dashoffset:0]",
												]}
											/>
										</svg>
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
		</div>
	</header>
</div>

<!-- Mobile: logo + hamburguesa -->
<header
	id="mobile-header"
	class="group/mobile fixed top-0 right-0 left-0 z-50 flex items-center justify-between px-5 py-5 transition-[background-color,backdrop-filter,padding,box-shadow] duration-500 ease-out lg:hidden data-scrolled:bg-launion/90 data-scrolled:py-3.5 data-scrolled:shadow-lg data-scrolled:backdrop-blur-md"
	data-force-scrolled={forceScrolled ? "" : undefined}
	data-scrolled={forceScrolled ? "" : undefined}
>
	<a href="/" aria-label="LA UNION S.R.L. - Inicio">
		<img
			src="/images/logos/logo-horizontal-blanco.svg"
			alt="LA UNION S.R.L."
			loading="lazy"
			class="h-3 w-auto transition-[height] duration-500 xs:h-4 sm:h-5 md:h-6 group-data-scrolled/mobile:h-3 group-data-scrolled/mobile:xs:h-4"
		/>
	</a>
	<button
		type="button"
		id="mobile-menu-btn"
		class="flex h-11 w-14 items-center justify-center rounded-l-2xl bg-white"
		aria-label="Abrir menú"
		aria-expanded="false"
		aria-controls="mobile-menu"
	>
		<svg
			width="22"
			height="16"
			viewBox="0 0 22 16"
			fill="none"
			xmlns="http://www.w3.org/2000/svg"
			aria-hidden="true"
		>
			<rect width="22" height="2.5" rx="1" fill="#000000"></rect>
			<rect y="6.75" width="22" height="2.5" rx="1" fill="#000000"></rect>
			<rect y="13.5" width="22" height="2.5" rx="1" fill="#000000"></rect>
		</svg>
	</button>
</header>

<!-- Mobile menu overlay -->
<div
	id="mobile-menu"
	class="pointer-events-none fixed inset-0 z-60 opacity-0 transition-opacity duration-300 lg:hidden"
	aria-hidden="true"
>
	<div
		id="mobile-menu-backdrop"
		class="absolute inset-0 bg-black/50"
	></div>
	<nav
		class="absolute top-0 right-0 flex h-full w-[min(100%,20rem)] translate-x-full flex-col bg-launion pt-24 transition-transform duration-300"
		aria-label="Menú móvil"
	>
		<ul class="flex flex-col gap-1 px-8">
			{
				navLinks.map((link) => {
					const active = isActiveLink(link.href);
					return (
						<li>
							<a
								href={link.href}
								class:list={[
									"mobile-nav-link relative block border-b border-white/20 py-4 pl-4 text-sm font-semibold tracking-wide text-white transition-colors duration-300",
									active && "border-l-[3px] border-l-white bg-white/10 text-white",
								]}
								aria-current={active ? "page" : undefined}
							>
								{link.label}
							</a>
						</li>
					);
				})
			}
		</ul>
	</nav>
</div>

<script>
	const desktopHeader = document.getElementById("desktop-header");
	const mobileHeader = document.getElementById("mobile-header");
	const headerLogo = desktopHeader?.querySelector(".header-logo");
	const SCROLL_THRESHOLD = 48;
	const forceScrolled =
		desktopHeader?.hasAttribute("data-force-scrolled") ||
		mobileHeader?.hasAttribute("data-force-scrolled");

	function setScrolled(scrolled: boolean) {
		const next = forceScrolled || scrolled;
		desktopHeader?.toggleAttribute("data-scrolled", next);
		mobileHeader?.toggleAttribute("data-scrolled", next);
		document.documentElement.classList.toggle("header-scrolled", next);

		if (headerLogo instanceof HTMLAnchorElement) {
			headerLogo.tabIndex = next ? 0 : -1;
			headerLogo.setAttribute("aria-hidden", next ? "false" : "true");
		}
	}

	function onScroll() {
		setScrolled(window.scrollY > SCROLL_THRESHOLD);
	}

	onScroll();
	if (!forceScrolled) {
		window.addEventListener("scroll", onScroll, { passive: true });
	}

	const menuBtn = document.getElementById("mobile-menu-btn");
	const menu = document.getElementById("mobile-menu");
	const backdrop = document.getElementById("mobile-menu-backdrop");
	const navPanel = menu?.querySelector("nav");
	const mobileNavLinks = menu?.querySelectorAll(".mobile-nav-link");

	function openMenu() {
		if (!menu || !menuBtn || !navPanel) return;
		menu.classList.remove("pointer-events-none", "opacity-0");
		menu.classList.add("opacity-100");
		navPanel.classList.remove("translate-x-full");
		menuBtn.setAttribute("aria-expanded", "true");
		menu.setAttribute("aria-hidden", "false");
		document.body.style.overflow = "hidden";
	}

	function closeMenu() {
		if (!menu || !menuBtn || !navPanel) return;
		menu.classList.add("pointer-events-none", "opacity-0");
		menu.classList.remove("opacity-100");
		navPanel.classList.add("translate-x-full");
		menuBtn.setAttribute("aria-expanded", "false");
		menu.setAttribute("aria-hidden", "true");
		document.body.style.overflow = "";
	}

	menuBtn?.addEventListener("click", () => {
		const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
		if (isOpen) closeMenu();
		else openMenu();
	});

	backdrop?.addEventListener("click", closeMenu);
	mobileNavLinks?.forEach((link) => link.addEventListener("click", closeMenu));
</script>
